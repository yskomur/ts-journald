{
  "name": "@yskomur/ts-journald",
  "version": "3.0.0",
  "description": "TypeScript and Node.js logger for systemd journald with structured logging, syslog priorities, cloud fallback, and support for SvelteKit, Express, Fastify, and NestJS services",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.esm.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && rollup -c",
    "build:watch": "rollup -c -w",
    "prepublishOnly": "npm run build",
    "type-check": "tsc --noEmit"
  },
  "author": "Yavuz Selim KOMUR <yskomur@gmail.com>",
  "contributors": [
    "Codex"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yskomur/ts-journald.git"
  },
  "bugs": {
    "url": "https://github.com/yskomur/ts-journald/issues"
  },
  "homepage": "https://github.com/yskomur/ts-journald#readme",
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "latest",
    "rollup": "^4.60.1",
    "tslib": "^2.8.1"
  },
  "files": [
    "dist",
    "llms.txt",
    "README.MD",
    "README-TR.MD",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "systemd",
    "journald",
    "logging",
    "typescript",
    "nodejs",
    "logger",
    "structured-logging",
    "structured-logger",
    "syslog",
    "systemd-journal",
    "linux-logging",
    "observability",
    "sveltekit",
    "express",
    "fastify",
    "nestjs",
    "serverless",
    "vercel",
    "aws",
    "gcp",
    "azure",
    "native-backend"
  ],
  "peerDependencies": {
    "@yskomur/node-sdjournal": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@yskomur/node-sdjournal": {
      "optional": true
    }
  }
}
